# ============================================================
# BACKEND ENVIRONMENT — örnek/şablon
# Bu dosyayı .env olarak kopyala ve gerçek anahtarlarını yaz.
# .env GİT'E YÜKLENMEZ (.gitignore'da olmalı).
# ============================================================

# ── Auth ──
JWT_SECRET=cok-uzun-rastgele-bir-string-buraya
PORT=3001

# ============================================================
# POSTGRESQL — Üyelik & kota (zorunlu)
# ============================================================
# Önce veritabanını oluşturun, sonra: cd backend && npm run migrate
#   createdb alerjitakvim   (veya pgAdmin'den)
DATABASE_URL=postgres://postgres:sifre@localhost:5432/alerjitakvim
# Yönetilen (bulut) Postgres SSL istiyorsa:
# DATABASE_SSL=true
# DB_POOL_MAX=10

# ============================================================
# KOTA LİMİTLERİ (günlük; boş bırakılırsa varsayılanlar kullanılır)
# ============================================================
# Misafir (girişsiz, IP bazlı)
ANON_POLLEN_DAILY=3
ANON_CHAT_DAILY=3
# Ücretsiz üye
FREE_POLLEN_DAILY=10
FREE_CHAT_DAILY=5
# Premium üye sınırsızdır (limit yok).

# ============================================================
# ÖDEME / PREMIUM (iyzico)
# ============================================================
# PAYMENT_MODE: 'simulate' (gerçek ödeme yok, varsayılan) | 'iyzico' (gerçek)
PAYMENT_MODE=simulate
PREMIUM_PRICE=49.99
PREMIUM_CURRENCY=TRY
PREMIUM_DAYS=30
# Gerçek iyzico için (PAYMENT_MODE=iyzico iken gerekir, önce: npm i iyzipay):
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# IYZICO_CALLBACK_URL=https://siteniz.com/api/membership/callback

# ============================================================
# GOOGLE POLLEN API — ÇOKLU ANAHTAR FALLBACK
# ============================================================
# Önerilen: virgülle ayır, istediğin kadar anahtar ekleyebilirsin.
# Sistem her zaman 1. anahtarı dener; kotası dolarsa otomatik 2.,
# o da bittiyse 3. ve sonrasına geçer. Aktif anahtar bellekte
# tutulur — her tıklamada baştan denenmez.
#
# Bloklama süreleri:
#   429 (rate-limit)        →  1 saat
#   403 (kota bitti / yasak) → 24 saat (gün dolar)
#   401 (auth)              → 10 dakika (geçici olabilir)
POLLEN_API_KEYS=AIzaSyXXXXX_birinci_anahtar,AIzaSyYYYYY_ikinci_anahtar,AIzaSyZZZZZ_ucuncu_anahtar

# Geriye uyumluluk: tek anahtar kullanmak istersen bunu da
# tanıyor. POLLEN_API_KEYS varsa o öncelikli — POLLEN_API_KEY
# yedek olarak kalır.
# POLLEN_API_KEY=AIzaSyXXXXX_tek_anahtar

# Not: Google'ın TÜM anahtarları tükendiğinde sistem otomatik
# olarak Open-Meteo'ya (CAMS Europe modeli) düşer. Bu sağlayıcı
# anahtar gerektirmez ve ücretsizdir — fallback için kayıt vs. yok.

# ============================================================
# GROQ (chatbot LLM)
# ============================================================
# Çoklu anahtarı virgülle ayır:
GROQ_API_KEYS=gsk_birinci,gsk_ikinci,gsk_ucuncu

# Model öncelik sırası (ilk model bitene kadar denenir, sonra sıradaki)
GROQ_MODELS=llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct,openai/gpt-oss-120b,openai/gpt-oss-20b

# ============================================================
# HuggingFace embeddings (RAG için, ilk indirmede gerekli)
# ============================================================
# Gerekirse mirror kullan (Türkiye'den hf.co'ya bağlanmıyorsa):
# HF_ENDPOINT=https://hf-mirror.com
# HF_HUB_CACHE=./hf-cache

# ============================================================
# GÜVENLİK & ÇALIŞMA ORTAMI (refactor sonrası eklenenler)
# ============================================================
# Çalışma ortamı: production'da JWT_SECRET ZORUNLU olur, hata detayları gizlenir.
NODE_ENV=development
# JWT geçerlilik süresi (varsayılan 7d)
# JWT_EXPIRES_IN=7d

# CORS: izin verilen origin'ler (virgülle ayır). BOŞSA tüm origin'lere açık
# (geliştirme kolaylığı). ÜRETİMDE frontend alan adınızı yazın:
# CORS_ORIGINS=https://alerjitakvim.com,https://www.alerjitakvim.com

# Reverse-proxy (Nginx) arkasındaki hop sayısı. IP bazlı kota güvenliği için
# 'true' yerine sayı kullanın. Tek Nginx için 1 (varsayılan).
TRUST_PROXY=1

# İstek gövdesi boyut limiti (büyük payload DoS'una karşı)
JSON_BODY_LIMIT=1mb

# Rate limiting — genel (tüm /api) ve auth'a özel (login/register, brute-force)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
