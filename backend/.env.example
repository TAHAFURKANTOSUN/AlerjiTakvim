

# ============================================================
# BACKEND ENVIRONMENT — örnek/şablon
# Bu dosyayı .env olarak kopyala ve gerçek anahtarlarını yaz.
# .env GİT'E YÜKLENMEZ (.gitignore'da olmalı).
# ============================================================

# ── Auth ──
JWT_SECRET=#26 karakterli rastgele bir string yazın (örn: openssl rand -hex 26)
# ============================================================
# POSTGRESQL — Üyelik & kota (zorunlu)
# ============================================================
# Önce veritabanını oluşturun, sonra: cd backend && npm run migrate
#   createdb alerjitakvim   (veya pgAdmin'den)
DATABASE_URL=postgres://postgres:(sifreniz)@localhost:5432/alerjitakvim
# Yönetilen (bulut) Postgres SSL istiyorsa:
# DATABASE_SSL=true
# DB_POOL_MAX=10

# ============================================================
# KOTA LİMİTLERİ (günlük; boş bırakılırsa varsayılanlar kullanılır)
# ============================================================
# Misafir (girişsiz, IP bazlı)
ANON_POLLEN_DAILY=3
ANON_CHAT_DAILY=3
# Ücretsiz üye
FREE_POLLEN_DAILY=10
FREE_CHAT_DAILY=5
# Premium üye sınırsızdır (limit yok).

# ============================================================
# ÖDEME / PREMIUM (iyzico)
# ============================================================
# PAYMENT_MODE: 'simulate' (gerçek ödeme yok, varsayılan) | 'iyzico' (gerçek)
PAYMENT_MODE=simulate
PREMIUM_PRICE=49.99
PREMIUM_CURRENCY=TRY
PREMIUM_DAYS=30
# Gerçek iyzico için (PAYMENT_MODE=iyzico iken gerekir, önce: npm i iyzipay):
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# IYZICO_CALLBACK_URL=https://siteniz.com/api/membership/callback

# ============================================================
# GOOGLE POLLEN API — ÇOKLU ANAHTAR FALLBACK
# ============================================================

#
# Bloklama süreleri:
#   429 (rate-limit)        →  1 saat
#   403 (kota bitti / yasak) → 24 saat (gün dolar)
#   401 (auth)              → 10 dakika (geçici olabilir)
#google pollen api keyleri girin 
POLLEN_API_KEYS=
POLLEN_API_KEYS=
POLLEN_API_KEY=




# ============================================================
# GROQ (chatbot LLM)
# ============================================================
#Groq API keyleri girin Çoklu anahtarı virgülle ayır:
GROQ_API_KEYS=
GROQ_API_KEYS=

# Model öncelik sırası (ilk model bitene kadar denenir, sonra sıradaki)
GROQ_MODELS=llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct,openai/gpt-oss-120b,openai/gpt-oss-20b

# 'true' yerine sayı kullanın. Tek Nginx için 1 (varsayılan).
TRUST_PROXY=1

# İstek gövdesi boyut limiti (büyük payload DoS'una karşı)
JSON_BODY_LIMIT=1mb

